# Platform-level gitignore
# ========================

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log

# Node.js (for platform-level scripts)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Platform workspace files
*.code-workspace

# Backup directories
backup-repos-*/